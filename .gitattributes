# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Java sources
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Scripts
*.sh text eol=lf
*.bat text eol=crlf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Documentation
*.md text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
